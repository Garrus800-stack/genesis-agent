{
  "name": "genesis-agent",
  "version": "7.4.9",
  "description": "A self-aware, self-verifying, self-evolving cognitive AI agent. Works with any LLM backend — Anthropic Claude, OpenAI, or local models via Ollama. It reads its own source code. It fixes its own bugs. It builds its own features. It thinks while you're away. It feels the consequences of its actions. It pursues goals autonomously. It verifies its own output programmatically. It learns what works for its specific model.",
  "main": "main.js",
  "scripts": {
    "start": "node scripts/start.js",
    "cli": "node cli.js",
    "cli:serve": "node cli.js --serve",
    "cli:minimal": "node cli.js --minimal",
    "demo": "node demo.js",
    "demo:quick": "node demo.js --quick",
    "test": "node test/index.js",
    "test:new": "node test/index.js --new",
    "test:ci": "c8 --check-coverage --lines 80 --branches 76 --functions 78 --reporter=text --include='src/agent/**/*.js' node test/index.js",
    "test:coverage": "c8 --reporter=text --reporter=html --reporter=lcov --include='src/**/*.js' --exclude='src/ui/**' node test/index.js",
    "test:coverage:report": "c8 report --reporter=text",
    "test:coverage:enforce": "c8 --check-coverage --lines 80 --branches 76 --functions 78 --reporter=text --include='src/agent/**/*.js' node test/index.js",
    "test:coverage:safety": "c8 --check-coverage --lines 80 --branches 70 --functions 75 --reporter=text --include='src/kernel/**' --include='src/agent/intelligence/CodeSafetyScanner.js' --include='src/agent/intelligence/VerificationEngine.js' --include='src/agent/foundation/Sandbox.js' --include='src/agent/foundation/WebFetcher.js' --include='src/agent/hexagonal/SelfModificationPipeline.js' --include='src/agent/hexagonal/MemoryFacade.js' node test/index.js",
    "audit:events": "node scripts/audit-events.js",
    "audit:events:strict": "node scripts/audit-events.js --strict",
    "audit:degradation": "node scripts/degradation-matrix.js",
    "audit:degradation:md": "node scripts/degradation-matrix.js --md --out",
    "typecheck": "tsc --project tsconfig.ci.json --noEmit",
    "build": "electron-builder",
    "build:bundle": "node scripts/build-bundle.js",
    "build:ci": "node scripts/build-bundle.js --ci",
    "build:ui": "node scripts/build-bundle.js",
    "build:watch": "node scripts/build-bundle.js --watch",
    "postinstall": "node scripts/build-bundle.js || echo [GENESIS] Optional bundle build skipped",
    "genesis": "node src/kernel/bootstrap.js",
    "typecheck:watch": "tsc --project tsconfig.ci.json --noEmit --watch",
    "audit:events:validate": "node scripts/validate-events.js",
    "audit:fitness": "node scripts/architectural-fitness.js",
    "audit:fitness:ci": "node scripts/architectural-fitness.js --ci",
    "ratchet": "node scripts/check-ratchet.js",
    "check:stale": "node scripts/check-stale-refs.js",
    "ratchet:fast": "node scripts/check-ratchet.js --skip-tests",
    "audit:fitness:json": "node scripts/architectural-fitness.js --json",
    "audit:channels": "node scripts/validate-channels.js",
    "ci": "npm test && node scripts/architectural-fitness.js --ci && node scripts/audit-events.js --strict && node scripts/validate-events.js && node scripts/validate-channels.js && node scripts/validate-service-wiring.js --strict && node scripts/validate-intent-wiring.js --strict",
    "ci:full": "npm test && node scripts/architectural-fitness.js --ci && node scripts/audit-events.js --strict && tsc --project tsconfig.ci.json --noEmit && node scripts/build-bundle.js --ci && node scripts/validate-events.js && node scripts/validate-channels.js && node scripts/validate-service-wiring.js --strict && node scripts/validate-intent-wiring.js --strict",
    "benchmark:agent": "node scripts/benchmark-agent.js",
    "benchmark:agent:quick": "node scripts/benchmark-agent.js --quick",
    "benchmark:agent:ab": "node scripts/benchmark-agent.js --ab",
    "benchmark:agent:ab:quick": "node scripts/benchmark-agent.js --ab --quick",
    "benchmark:agent:ab:matrix": "node scripts/benchmark-agent.js --ab-matrix",
    "benchmark:agent:layer": "node scripts/benchmark-agent.js --ab-layer",
    "benchmark:agent:layer:organism": "node scripts/benchmark-agent.js --ab-layer 7 --quick",
    "benchmark:agent:layer:full": "node scripts/benchmark-agent.js --ab-layer 7,13 --quick",
    "benchmark:readme": "node scripts/benchmark-readme.js",
    "benchmark:readme:dry": "node scripts/benchmark-readme.js --dry-run",
    "fitness:trend": "node scripts/fitness-trend.js",
    "fitness:trend:show": "node scripts/fitness-trend.js --show",
    "fitness:trend:ci": "node scripts/fitness-trend.js --ci --threshold 2",
    "test:colony": "node scripts/colony-test.js",
    "test:colony:dry": "node scripts/colony-test.js --dry-run",
    "test:deploy": "node scripts/deploy-test.js",
    "test:e2e": "npx electron test/modules/e2e-electron.test.js",
    "coverage:ratchet": "npm run test:coverage 2>&1 | node scripts/coverage-ratchet.js",
    "coverage:ratchet:dry": "npm run test:coverage 2>&1 | node scripts/coverage-ratchet.js --dry-run",
    "release:notes": "node scripts/release-notes.js",
    "release:notes:copy": "node scripts/release-notes.js --copy",
    "release:notes:file": "node scripts/release-notes.js --file",
    "release:zip": "node scripts/release-zip.js",
    "release:zip:dry": "node scripts/release-zip.js --dry-run",
    "scan:schemas": "node scripts/scan-schemas.js",
    "audit:services": "node scripts/validate-service-wiring.js",
    "audit:services:strict": "node scripts/validate-service-wiring.js --strict",
    "audit:intents": "node scripts/validate-intent-wiring.js",
    "audit:intents:strict": "node scripts/validate-intent-wiring.js --strict"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Garrus800-stack/genesis-agent.git"
  },
  "homepage": "https://github.com/Garrus800-stack/genesis-agent#readme",
  "bugs": {
    "url": "https://github.com/Garrus800-stack/genesis-agent/issues"
  },
  "keywords": [
    "ai-agent",
    "autonomous-agent",
    "self-modifying",
    "self-repairing",
    "electron",
    "ollama",
    "local-llm",
    "knowledge-graph",
    "mcp",
    "model-context-protocol",
    "code-mode",
    "self-aware",
    "desktop-ai",
    "vector-embeddings",
    "hexagonal-architecture",
    "verification-engine",
    "meta-learning",
    "episodic-memory",
    "formal-planning",
    "cognitive-agent"
  ],
  "author": "Daniel (Garrus800-stack)",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "acorn": "~8.16.0",
    "chokidar": "~3.6.0",
    "tree-kill": "~1.2.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "c8": "^9.1.0",
    "electron": "^39.0.0",
    "electron-builder": "^26.0.0",
    "esbuild": "^0.24.2",
    "typescript": "^5.5.0"
  },
  "optionalDependencies": {
    "cheerio": "^1.0.0",
    "monaco-editor": "^0.44.0",
    "puppeteer": "^22.0.0"
  },
  "overrides": {
    "@xmldom/xmldom": "^0.9.8",
    "basic-ftp": "^5.0.5"
  }
}
